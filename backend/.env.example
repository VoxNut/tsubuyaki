# Local directory wins when it is set.
FURIGANA_MODEL_LOCAL_DIR=

# Remote repository configuration. Revision must be an immutable commit SHA.
FURIGANA_HF_MODEL_REPO=
FURIGANA_HF_MODEL_REVISION=
HF_TOKEN=
FURIGANA_HF_CACHE_DIR=/tmp/huggingface

# Runtime
FURIGANA_DEVICE=auto
FURIGANA_INFERENCE_BATCH_SIZE=16
FURIGANA_MAX_CUES_PER_REQUEST=64
FURIGANA_MAX_CHARS_PER_CUE=2000
FURIGANA_MAX_TOTAL_CHARS=32000
FURIGANA_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
FURIGANA_LOG_LEVEL=INFO
